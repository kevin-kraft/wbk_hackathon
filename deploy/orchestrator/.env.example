# Copy to `.env` and point each stage at wherever it actually runs.
PERCEPTION_YOLO_URL=http://GPU_SERVER:8001
PERCEPTION_SAM3_URL=http://GPU_SERVER:8002
PERCEPTION_LOCATE_URL=http://GPU_SERVER:8003
POSE_URL=http://GPU_SERVER:8004
DAMAGE_URL=http://DAMAGE_HOST:8006
# Teammate-owned Jetson endpoints:
MOVEMENT_URL=http://JETSON:9000
GRIP_URL=http://JETSON:9001
# Shared API token: REQUIRED on /run + /events/run, and SENT to perception/pose/
# damage. Must match those services' WBK_API_TOKEN. Empty = auth disabled.
WBK_API_TOKEN=
# Optional hand-eye calibration (flat-16 row-major JSON); set units to mm if needed.
# T_BASE_CAM=[...]
# T_BASE_CAM_UNITS=mm
