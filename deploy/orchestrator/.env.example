PERCEPTION_SAM3_URL=http://GPU_SERVER:8002
PERCEPTION_LOCATE_URL=http://GPU_SERVER:8003
POSE_URL=http://GPU_SERVER:8004
DAMAGE_URL=http://DAMAGE_HOST:8006
