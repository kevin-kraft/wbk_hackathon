# Copy to `.env` and fill in for the Jetson.
# Robot socket server (LARA5/NEURA) — usually localhost on the Jetson:
ROBOT_HOST=127.0.0.1
ROBOT_PORT=65432
SOCKET_TIMEOUT=2.0
# API bind (host networking): serve the movement API on :9000.
API_PORT=9000
# KIP pose API used by the hover planner:
KIP_API_BASE=https://max-utils.com/KIP/api
KIP_PIPELINE=gdrnpp
# Raw passthrough endpoint (/robot/raw). Set false to disable in production.
ALLOW_RAW_ROBOT_COMMANDS=true
# Shared API token guarding all routes (must match the orchestrator's). Empty = off.
WBK_API_TOKEN=
