# Copy to `.env` and fill in for the Jetson.
# Backend: zivid (real camera) | mock (synthetic) | file (from disk).
SCENE_CAMERA_BACKEND=zivid
# Optional Zivid Studio settings preset (YAML). Empty = default single-acquisition.
ZIVID_SETTINGS_PATH=
# Pin intrinsics if the SDK read is unavailable (flat-9 row-major JSON), e.g.
# SCENE_K=[1780,0,972,0,1780,600,0,0,1]
SCENE_K=
# Clamp for the 16-bit depth PNG (mm).
SCENE_DEPTH_MAX_MM=65535
# Shared API token guarding /capture (must match the orchestrator's). Empty = off.
WBK_API_TOKEN=
