# Build-time DEFAULTS for service endpoints. These are baked into the bundle and
# act as fallbacks only — the preferred way to point the dashboard at your
# machines is public/config.json (editable after build) or the Settings page
# (live, per-browser). Precedence: Settings override > config.json > these > localhost.
#
# Copy to `.env` and adjust, or ignore entirely and just edit public/config.json.

VITE_ORCHESTRATOR_URL=http://localhost:8000
VITE_YOLO_URL=http://localhost:8001
VITE_SAM3_URL=http://localhost:8002
VITE_LOCATEANYTHING_URL=http://localhost:8003
VITE_FOUNDATIONPOSE_URL=http://localhost:8004
VITE_GIGAPOSE_URL=http://localhost:8005
VITE_DAMAGE_URL=http://localhost:8006
VITE_MOVEMENT_URL=http://jetson.local:9000
VITE_GRIP_URL=http://jetson.local:9001
VITE_SCENE_CAMERA_URL=http://localhost:8080/stream.mjpg
VITE_INSPECTION_CAMERA_URL=
# Shared API token (must match the services' WBK_API_TOKEN). Empty = don't send one.
VITE_API_TOKEN=
